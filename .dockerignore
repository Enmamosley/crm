# Dependencies (composer install runs inside Docker)
node_modules
vendor
npm-debug.log*

# Git
.git
.gitignore
.gitattributes

# Environment files (never bake secrets into the image)
.env
.env.*
!.env.example

# Built assets (generated inside Docker via multi-stage build)
public/build

# Laravel cache/runtime (generated at container startup)
storage/framework/cache/data
storage/framework/sessions
storage/framework/views
storage/logs/*.log

# Docker compose (not needed inside image; Dockerfile IS needed)
docker-compose*.yml
docker-compose*.yaml

# Dev/test artifacts
tests/
coverage/
.phpunit.result.cache
phpunit.xml

# Docs and extras
*.md
!README.md
docker-compose.override.yml

# Local-only subdirectories not part of the app
tailadmin-laravel-pro-main/
api-modules-1.0.6/

# macOS
.DS_Store
